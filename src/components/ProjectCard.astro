---
import type { Project } from '../data/projects';

type Props = {
  project: Project;
  featured?: boolean;
};

const { project, featured = false } = Astro.props;
---

<article class:list={['project-card', `project-card--${project.accent}`, { 'project-card--featured': featured }]} data-reveal>
  <div class="project-card__topline">
    <span>{project.category}</span>
    <span aria-hidden="true">/{project.slug}</span>
  </div>
  <div class="project-card__logo">
    <img src={project.logo} alt={project.logoAlt} width="1024" height="683" loading="lazy" decoding="async" />
  </div>
  <div class="project-card__content">
    <h3>{project.title}</h3>
    <p>{project.description}</p>
  </div>
  <ul class="tag-list" aria-label={`Schwerpunkte von ${project.title}`}>
    {project.tags.map((tag) => <li>{tag}</li>)}
  </ul>
  <a class="project-card__link" href={project.url} target="_blank" rel="noopener noreferrer">
    <span>{project.cta}</span>
    <svg aria-hidden="true" viewBox="0 0 20 20">
      <path d="M6 14 14 6m0 0H7m7 0v7" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" />
    </svg>
  </a>
</article>
