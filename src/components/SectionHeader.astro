---
type Props = {
  eyebrow?: string;
  title: string;
  text?: string;
  align?: 'left' | 'center';
};

const { eyebrow, title, text, align = 'left' } = Astro.props;
---

<div class:list={['section-header', `section-header--${align}`]} data-reveal>
  {eyebrow && <p class="eyebrow">{eyebrow}</p>}
  <h2>{title}</h2>
  {text && <p>{text}</p>}
</div>
