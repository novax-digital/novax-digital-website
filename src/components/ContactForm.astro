---
import { legalData } from '../data/legal';

const projectOptions = [
  'Allgemein',
  'Erfolg Buddies',
  'Deutsche Pflegeentwicklung',
  'Schulung Immobilienmakler',
  'Passflow',
  'Neues Projekt',
];
---

<form class="contact-form" method="post" action="#" novalidate data-contact-form data-mail={legalData.email}>
  <div class="form-status" role="status" aria-live="polite" data-form-status>
    Das Formular ist anschlussfertig vorbereitet. Fuer die Produktion muss ein API-Endpunkt oder Form-Service verbunden werden.
  </div>

  <div class="field-grid">
    <div class="field">
      <label for="name">Name</label>
      <input id="name" name="name" type="text" autocomplete="name" required minlength="2" />
      <p class="field-error" id="name-error"></p>
    </div>

    <div class="field">
      <label for="email">E-Mail</label>
      <input id="email" name="email" type="email" autocomplete="email" required />
      <p class="field-error" id="email-error"></p>
    </div>
  </div>

  <div class="field-grid">
    <div class="field">
      <label for="company">Unternehmen <span>optional</span></label>
      <input id="company" name="company" type="text" autocomplete="organization" />
      <p class="field-error" id="company-error"></p>
    </div>

    <div class="field">
      <label for="project">Projekt / Betreff</label>
      <select id="project" name="project" required>
        {projectOptions.map((option) => <option value={option}>{option}</option>)}
      </select>
      <p class="field-error" id="project-error"></p>
    </div>
  </div>

  <div class="field">
    <label for="message">Nachricht</label>
    <textarea id="message" name="message" rows="7" required minlength="20"></textarea>
    <p class="field-error" id="message-error"></p>
  </div>

  <div class="field field--checkbox">
    <input id="privacy" name="privacy" type="checkbox" required />
    <label for="privacy">
      Ich habe die <a href="/datenschutz/">Datenschutzhinweise</a> gelesen und stimme der Verarbeitung meiner Angaben zur Kontaktaufnahme zu.
    </label>
    <p class="field-error" id="privacy-error"></p>
  </div>

  <div class="field field--honeypot" aria-hidden="true">
    <label for="website">Website</label>
    <input id="website" name="website" type="text" tabindex="-1" autocomplete="off" />
  </div>

  <div class="contact-form__actions">
    <button class="button button--primary" type="submit">Anfrage prüfen</button>
    <a class="button button--ghost" href={`mailto:${legalData.email}`}>Direkt per E-Mail</a>
  </div>
</form>

<script>
  const form = document.querySelector<HTMLFormElement>('[data-contact-form]');
  const status = document.querySelector<HTMLElement>('[data-form-status]');

  const messages: Record<string, string> = {
    name: 'Bitte gib deinen Namen an.',
    email: 'Bitte gib eine gueltige E-Mail-Adresse an.',
    project: 'Bitte waehle ein Projekt oder Thema.',
    message: 'Bitte beschreibe dein Anliegen mit mindestens 20 Zeichen.',
    privacy: 'Bitte bestaetige die Datenschutzhinweise.',
  };

  const setError = (field: HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement, message = '') => {
    const error = document.getElementById(`${field.name}-error`);
    if (!error) return;

    error.textContent = message;
    field.toggleAttribute('aria-invalid', Boolean(message));
    if (message) {
      field.setAttribute('aria-describedby', error.id);
    } else {
      field.removeAttribute('aria-describedby');
    }
  };

  const validateField = (field: HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement) => {
    if (field.name === 'website') return true;
    const valid = field.checkValidity();
    setError(field, valid ? '' : messages[field.name] ?? 'Bitte pruefe dieses Feld.');
    return valid;
  };

  form?.addEventListener('input', (event) => {
    const target = event.target;
    if (target instanceof HTMLInputElement || target instanceof HTMLTextAreaElement || target instanceof HTMLSelectElement) {
      validateField(target);
    }
  });

  form?.addEventListener('submit', (event) => {
    event.preventDefault();
    if (!form) return;

    const fields = Array.from(form.elements).filter(
      (element): element is HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement =>
        element instanceof HTMLInputElement || element instanceof HTMLTextAreaElement || element instanceof HTMLSelectElement,
    );

    const isSpam = form.website instanceof HTMLInputElement && form.website.value.trim().length > 0;
    const isValid = fields.map(validateField).every(Boolean) && !isSpam;

    if (!isValid) {
      status?.classList.add('is-error');
      if (status) status.textContent = 'Bitte pruefe die markierten Felder.';
      fields.find((field) => field.hasAttribute('aria-invalid'))?.focus();
      return;
    }

    const data = new FormData(form);
    const email = form.dataset.mail ?? 'info@novax-digital.de';
    const subject = encodeURIComponent(`Novax Anfrage: ${data.get('project')}`);
    const body = encodeURIComponent(
      [
        `Name: ${data.get('name')}`,
        `E-Mail: ${data.get('email')}`,
        `Unternehmen: ${data.get('company') || '-'}`,
        `Projekt/Betreff: ${data.get('project')}`,
        '',
        String(data.get('message')),
      ].join('\n'),
    );

    status?.classList.remove('is-error');
    status?.classList.add('is-notice');
    if (status) {
      status.innerHTML =
        'Die Angaben sind valide. Das Formular ist noch nicht mit einem Versanddienst verbunden. <a href="mailto:' +
        email +
        '?subject=' +
        subject +
        '&body=' +
        body +
        '">Anfrage jetzt per E-Mail öffnen</a>.';
    }
  });
</script>
