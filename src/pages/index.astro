---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ValueCard from '../components/ValueCard.astro';
import { legalData } from '../data/legal';
import { projects } from '../data/projects';

const focusAreas = [
  {
    title: 'Build',
    text: 'Idee. Design. Code.',
  },
  {
    title: 'Launch',
    text: 'Sichtbar. Schnell. Klar.',
  },
  {
    title: 'Scale',
    text: 'Messen. Automatisieren. Wachsen.',
  },
];

const projectBadges: Record<string, string> = {
  'erfolg-buddies': 'Marke',
  'deutsche-pflegeentwicklung': 'Portal',
  'schulung-immobilienmakler': 'Portal',
  passflow: 'Tool',
};

const projectOrder = ['deutsche-pflegeentwicklung', 'schulung-immobilienmakler', 'passflow', 'erfolg-buddies'];
const displayedProjects = projectOrder
  .map((slug) => projects.find((project) => project.slug === slug))
  .filter((project) => project !== undefined);

const phoneHref = legalData.phone ? `tel:${legalData.phone.replace(/\D/g, '')}` : null;
---

<BaseLayout
  title="Novax Digital GmbH"
  description="Novax Digital entwickelt Websites, Plattformen, Schulungsportale, SaaS-Tools und digitale Wachstumssysteme aus Hannover."
>
  <Hero />

  <section class="section section--tight projects-showcase" id="projekte" aria-labelledby="projects-title">
    <div class="landing-heading landing-heading--center" data-reveal>
      <h2 id="projects-title">Digitale Tools &amp; Produkte</h2>
      <p>Eigene Plattformen. Reale Märkte. Klare Links.</p>
    </div>
    <div class="project-brand-grid" aria-label="Novax Digital Projekte" data-reveal>
      {displayedProjects.map((project, index) => (
        <a
          class:list={['project-logo-card', `project-logo-card--${project.accent}`]}
          style={`--card-index:${index}`}
          href={project.url}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={`${project.title} in neuem Tab öffnen`}
        >
          <span>{projectBadges[project.slug] ?? 'Projekt'}</span>
          <img src={project.logo} alt={project.logoAlt} width="1024" height="683" loading="lazy" decoding="async" />
        </a>
      ))}
    </div>
  </section>

  <section class="section landing-about" id="ueber-uns" aria-labelledby="about-title">
    <div class="landing-about__media" data-reveal>
      <figure class="landing-about__image">
        <img
          src="/assets/optimized/team-founders-1600.jpg"
          alt="Philipp Polley und Christoph Pfad von Novax Digital"
          width="1600"
          height="1066"
          loading="lazy"
          decoding="async"
        />
      </figure>
    </div>
    <div class="landing-about__content" data-reveal>
      <p class="eyebrow">Über Novax</p>
      <h2 id="about-title">Wir bauen, was wir selbst gern nutzen würden.</h2>
      <p>Hannover. Eigene Produkte. Digitale Systeme mit Haltung.</p>
    </div>
  </section>

  <section class="section section--band landing-focus impact-wall" aria-labelledby="focus-title">
    <div class="landing-heading" data-reveal>
      <p class="eyebrow">Modus</p>
      <h2 id="focus-title">Build. Launch. Scale.</h2>
    </div>
    <div class="value-grid">
      {focusAreas.map((value, index) => <ValueCard title={value.title} text={value.text} index={index} />)}
    </div>
  </section>

  <section class="section contact-cta landing-contact" id="kontakt" aria-labelledby="contact-cta-title" data-reveal>
    <div>
      <p class="eyebrow">Kontakt</p>
      <h2 id="contact-cta-title">Lass uns etwas Starkes bauen.</h2>
      <p>Ein Anruf. Eine Mail. Der erste Schritt.</p>
    </div>
    <div class="contact-cta__actions">
      {legalData.phone && phoneHref && <a class="button button--primary" href={phoneHref}>{legalData.phone}</a>}
      <a class="button button--ghost" href={`mailto:${legalData.email}`}>{legalData.email}</a>
    </div>
  </section>
</BaseLayout>
