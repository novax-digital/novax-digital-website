---
const target = '/#ueber-uns';
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta http-equiv="refresh" content={`0; url=${target}`} />
    <link rel="canonical" href="https://novax-digital.de/" />
    <title>Über uns | Novax Digital</title>
  </head>
  <body>
    <script is:inline>
      window.location.replace('/#ueber-uns');
    </script>
    <p><a href={target}>Weiter zu Über uns</a></p>
  </body>
</html>
