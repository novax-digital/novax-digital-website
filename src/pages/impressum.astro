---
import BaseLayout from '../layouts/BaseLayout.astro';
import { legalData } from '../data/legal';
---

<BaseLayout
  title="Impressum"
  description="Impressum der Novax Digital GmbH mit Angaben nach deutschem Recht."
>
  <section class="page-hero section page-hero--compact legal-hero" aria-labelledby="imprint-title">
    <div data-reveal>
      <p class="eyebrow">Rechtliches</p>
      <h1 id="imprint-title">Impressum</h1>
      <p>Angaben nach § 5 DDG.</p>
    </div>
  </section>

  <section class="section legal-content legal-content--centered" data-reveal>
    <h2>Angaben zum Unternehmen</h2>
    <p>
      <strong>{legalData.company}</strong><br />
      {legalData.address.street}<br />
      {legalData.address.postalCode} {legalData.address.city}
    </p>

    <h2>Vertreten durch</h2>
    <p>Geschaeftsfuehrer: {legalData.managingDirectors.join(', ')}</p>

    <h2>Kontakt</h2>
    <p>
      {legalData.phone && (
        <>
          Telefon: <a href={`tel:${legalData.phone.replace(/\D/g, '')}`}>{legalData.phone}</a><br />
        </>
      )}
      E-Mail: <a href={`mailto:${legalData.email}`}>{legalData.email}</a>
    </p>

    <h2>Registereintrag</h2>
    <p>
      Registergericht: {legalData.registerCourt}<br />
      Registernummer: {legalData.registerNumber}
    </p>

    <h2>Umsatzsteuer-ID</h2>
    <p>Umsatzsteuer-Identifikationsnummer gemaess § 27a Umsatzsteuergesetz: {legalData.vatId}</p>
  </section>
</BaseLayout>
